DATABASE_URL=postgresql://i3e:i3e_dev_only@localhost:5432/i3e
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-random-characters
TRUST_PROXY_HEADERS=true

# Generic OIDC admin login
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ALLOWED_EMAILS=
SEED_ADMIN_OIDC_SUBJECT=
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=Administrator

# Machine translation
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
TRANSLATION_CRON_SECRET=replace-me

# Private object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-1
S3_BUCKET=i3e-private
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_dev_only
S3_FORCE_PATH_STYLE=true

# Notifications and malware scanning
SMTP_URL=smtp://localhost:1025
MAIL_FROM=web@i3einformatica.com
MAIL_TO=info@i3einformatica.com
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Retención inicial; validar con DPO antes de producción
RETENTION_CONTACT_DAYS=365
RETENTION_JOBS_DAYS=180
RETENTION_COMPLAINT_DAYS=1825
