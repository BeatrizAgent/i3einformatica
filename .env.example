# Local static-site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# GitHub Pages project path. Leave empty for a custom domain or root hosting.
NEXT_PUBLIC_BASE_PATH=

# Secure complaints receiver. Public URL only; do not put secrets in NEXT_PUBLIC_*.
# Expected request: multipart/form-data with reportType, consultationType,
# observations, privacyAccepted, locale, source and one or more files fields.
NEXT_PUBLIC_COMPLAINTS_ENDPOINT=
# Client-side guardrails; the receiving service must enforce them server-side too.
NEXT_PUBLIC_COMPLAINTS_MAX_FILE_MB=10
NEXT_PUBLIC_COMPLAINTS_MAX_FILES=5
